{
  "name": "syunkan-eisaku",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,wrangler -c blue,yellow \"vite\" \"wrangler pages dev --proxy 5173 --port 8788\"",
    "dev:pages": "wrangler pages dev --proxy 5173 --port 8788",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist",
    "kv:create": "wrangler kv namespace create RESULTS_KV"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dexie": "^4.0.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wrangler": "^4.71.0"
  }
}
